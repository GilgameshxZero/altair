{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "clean",
			"options": {
				"cwd": "${workspaceFolder}/build"
			},
			"presentation": {
				"clear": true,
				"reveal": "never",
				"close": true
			},

			"command": "make",
			"args": ["clean"]
		},
		{
			"type": "shell",
			"label": "new",
			"options": {
				"cwd": "${workspaceFolder}/build"
			},
			"presentation": {
				"clear": true,
				"reveal": "always",
				"close": true
			},

			"command": "cp",
			"args": [
				"template.cpp",
				"${fileDirname}/${input:new-name}.cpp",
				"&&",
				"code",
				"${fileDirname}/${input:new-name}.cpp"
			]
		},
		{
			"type": "shell",
			"label": "build.debug.x64",
			"options": {
				"cwd": "${workspaceFolder}/build"
			},
			"presentation": { "clear": true, "reveal": "never" },
			"group": { "kind": "build", "isDefault": true },

			"command": "make",
			"args": [
				"PROJ=${relativeFileDirname}",
				"BIN=${fileBasenameNoExtension}"
			],
			"problemMatcher": ["$codelldb-rustc"],
			"windows": { "problemMatcher": ["$msCompile"] }
		},
		{
			"label": "build.release.x64",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}/build"
			},
			"presentation": { "clear": true, "reveal": "never" },
			"group": "build",

			"command": "make",
			"args": [
				"PROJ=${relativeFileDirname}",
				"BIN=${fileBasenameNoExtension}",
				"BUILD=1"
			],
			"problemMatcher": ["$codelldb-rustc"],
			"windows": { "problemMatcher": ["$msCompile"] }
		}
	],
	"inputs": [
		{
			"id": "new-name",
			"description": "Name:",
			"default": "a",
			"type": "promptString"
		}
	]
}
